{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "shillem-plugins",
  "owner": {
    "name": "Shillem Volpato",
    "email": "volpato.sh@gmail.com"
  },
  "metadata": {
    "description": "Directory of Claude Code plugins",
    "version": "1.1.3"
  },
  "plugins": [
    {
      "name": "apex-lsp",
      "description": "Salesforce Apex language server for enhanced code intelligence",
      "version": "1.0.0",
      "author": {
        "name": "Shillem Volpato",
        "email": "volpato.sh@gmail.com"
      },
      "source": "./plugins/apex-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "apex": {
          "command": "java",
          "args": [
            "-cp",
            "${SF_LSP_APEX}",
            "-Ddebug.internal.errors=true",
            "-Ddebug.semantic.errors=false",
            "-Ddebug.completion.statistics=false",
            "-Dlwc.typegeneration.disabled=true",
            "apex.jorje.lsp.ApexLanguageServerLauncher"
          ],
          "extensionToLanguage": {
            ".cls": "apex",
            ".trigger": "apex",
            ".apex": "apex"
          }
        }
      }
    },
    {
      "name": "esdd",
      "description": "Express spec-driven development — lightweight, customizable, building living specs that document your project's intent over time",
      "version": "1.0.2",
      "author": {
        "name": "Shillem Volpato",
        "email": "volpato.sh@gmail.com"
      },
      "source": "./plugins/esdd",
      "category": "development",
      "strict": false
    },
    {
      "name": "scala-lsp",
      "description": "Scala language server for enhanced code intelligence",
      "version": "1.0.0",
      "author": {
        "name": "Shillem Volpato",
        "email": "volpato.sh@gmail.com"
      },
      "source": "./plugins/scala-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "scala": {
          "command": "metals",
          "extensionToLanguage": {
            ".sbt": "sbt",
            ".sc": "scala",
            ".scala": "scala"
          }
        }
      }
    },
    {
      "name": "stickies",
      "description": "Manage stickies as markdown files",
      "version": "1.0.3",
      "author": {
        "name": "Shillem Volpato",
        "email": "volpato.sh@gmail.com"
      },
      "source": "./plugins/stickies",
      "category": "productivity",
      "strict": false
    }
  ]
}
